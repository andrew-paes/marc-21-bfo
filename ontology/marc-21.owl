    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#publisher</IRI>
        <Literal xml:lang="en-us">A company or publishing entity responsible for the financing, production, and commercial distribution of publications.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#publisher</IRI>
        <Literal xml:lang="pt-br">Empresa ou entidade editorial responsável pelo financiamento, produção e distribuição comercial de publicações.</Literal>
