    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#library</IRI>
        <Literal xml:lang="en-us">A physical institution responsible for the custody, processing, and dissemination of bibliographic collections.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#library</IRI>
        <Literal xml:lang="pt-br">Instituição material responsável pela custódia, processamento e disseminação do acervo bibliográfico.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#person</IRI>
        <Literal xml:lang="en-us">Person</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#person</IRI>
        <Literal xml:lang="pt-br">Pessoa</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#person</IRI>
        <Literal xml:lang="en-us">A biological and real human individual. A concrete being that exists in time and retains its own identity over time while undergoing changes.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#person</IRI>
        <Literal xml:lang="pt-br">É o indivíduo humano biológico e real. O ser concreto que existe no tempo que retém sua identidade própria ao longo do tempo enquanto passa por mudanças.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#publisher</IRI>
        <Literal xml:lang="pt-br">Editora</Literal>
